@page "/configuration"
@rendermode InteractiveServer
@inject AgentSettingsStore Store
@inject HarvesterRuntime Runtime
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Configuration</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Harvesting configuration</MudText>
<MudText Typo="Typo.body2" Class="mb-4">
    Add one or more upload targets. For each watcher path, use <strong>Include subdirectories</strong> when you want the whole tree monitored.
    Leave upload file filters empty to use defaults (*.exe, *.dll, *.sys, *.pdb). Deletion is configured per watched path.
</MudText>

<MudStack Spacing="3">
    @for (var i = 0; i < _doc.Servers.Count; i++)
    {
        var idx = i;
        var server = _doc.Servers[idx];
        <MudExpansionPanel Text="@GetServerPanelTitle(idx, server)">
            <MudStack Spacing="2">
                <MudTextField @bind-Value="server.DisplayName" Label="Display name" Variant="Variant.Outlined"
                              HelperText="Optional; shown in Dashboard file activity instead of the URL." />
                <MudTextField @bind-Value="_serverUrls[idx]" Label="Server URL" Variant="Variant.Outlined"
                              HelperText="e.g. http://192.168.1.10:5000/" />
                <MudTextField @bind-Value="server.Authentication.Username" Label="Username" Variant="Variant.Outlined" />
                <MudTextField @bind-Value="server.Authentication.Password" Label="Password" Variant="Variant.Outlined"
                              InputType="InputType.Password" />

                <MudText Typo="Typo.subtitle2">Watcher paths</MudText>
                @for (var w = 0; w < server.WatcherPaths.Count; w++)
                {
                    var wj = w;
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="flex-wrap">
                        <MudTextField @bind-Value="server.WatcherPaths[wj].Path" Label="Directory" Variant="Variant.Outlined"
                                      Margin="Margin.Dense" Class="flex-grow-1" Style="min-width: 12rem;" />
                        <MudIconButton Icon="@Icons.Material.Filled.FolderOpen" aria-label="Browse directory"
                                       OnClick="@(() => BrowseWatcherPathAsync(server, wj))" />
                        <MudSwitch @bind-Value="server.WatcherPaths[wj].IncludeSubdirectories"
                                   Label="Include subdirectories" Color="Color.Primary" />
                        <MudSwitch @bind-Value="server.WatcherPaths[wj].DeleteAfterUpload" Color="Color.Warning"
                                   Label="Delete after successful upload" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Remove path"
                                       OnClick="@(() => RemoveAt(server.WatcherPaths, wj))" />
                    </MudStack>

                    <MudStack Spacing="2" Class="ml-2 mb-4">
                        <MudText Typo="Typo.subtitle2">Upload file filters (this watched path)</MudText>
                        @for (var f = 0; f < server.WatcherPaths[wj].UploadFileFilters.Count; f++)
                        {
                            var fj = f;
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                <MudTextField @bind-Value="server.WatcherPaths[wj].UploadFileFilters[fj]" Variant="Variant.Outlined"
                                              Margin="Margin.Dense" Class="flex-grow-1" HelperText="e.g. *.pdb" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Remove filter"
                                               OnClick="@(() => RemoveAt(server.WatcherPaths[wj].UploadFileFilters, fj))" />
                            </MudStack>
                        }
                        <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Add"
                                   OnClick='@(() => server.WatcherPaths[wj].UploadFileFilters.Add("*.pdb"))'>
                            Add filter
                        </MudButton>

                        <MudText Typo="Typo.subtitle2">Deletion inclusion (globs)</MudText>
                        @for (var di = 0; di < server.WatcherPaths[wj].DeletionInclusionFilter.Count; di++)
                        {
                            var dj = di;
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                <MudTextField @bind-Value="server.WatcherPaths[wj].DeletionInclusionFilter[dj]" Variant="Variant.Outlined"
                                              Margin="Margin.Dense" Class="flex-grow-1" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Remove pattern"
                                               OnClick="@(() => RemoveAt(server.WatcherPaths[wj].DeletionInclusionFilter, dj))" />
                            </MudStack>
                        }
                        <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Add"
                                   OnClick='@(() => server.WatcherPaths[wj].DeletionInclusionFilter.Add("**/*.pdb"))'>
                            Add pattern
                        </MudButton>

                        <MudText Typo="Typo.subtitle2">Deletion exclusion (globs)</MudText>
                        @for (var ei = 0; ei < server.WatcherPaths[wj].DeletionExclusionFilter.Count; ei++)
                        {
                            var ej = ei;
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                <MudTextField @bind-Value="server.WatcherPaths[wj].DeletionExclusionFilter[ej]" Variant="Variant.Outlined"
                                              Margin="Margin.Dense" Class="flex-grow-1" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Remove pattern"
                                               OnClick="@(() => RemoveAt(server.WatcherPaths[wj].DeletionExclusionFilter, ej))" />
                            </MudStack>
                        }
                        <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Add"
                                   OnClick='@(() => server.WatcherPaths[wj].DeletionExclusionFilter.Add(""))'>
                            Add pattern
                        </MudButton>
                    </MudStack>
                }
                <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Add"
                           OnClick="@(() => server.WatcherPaths.Add(new WatcherPathEntry()))">
                    Add watcher path
                </MudButton>

                <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete"
                           OnClick="@(() => RemoveServer(idx))">
                    Remove this server
                </MudButton>
            </MudStack>
        </MudExpansionPanel>
    }

    <MudButton Variant="Variant.Filled" Color="Color.Default" StartIcon="@Icons.Material.Filled.Add"
               OnClick="AddServer">
        Add server
    </MudButton>

    <MudStack Row="true" Spacing="2">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync">Save and apply</MudButton>
        <MudButton Variant="Variant.Outlined" OnClick="Reload">Reload from disk</MudButton>
    </MudStack>
</MudStack>

@code {
    private AgentSettingsDocument _doc = null!;
    private List<string> _serverUrls = [];

    protected override void OnInitialized()
    {
        Reload();
    }

    private void Reload()
    {
        _doc = Store.GetSnapshot();
        _serverUrls = _doc.Servers.Select(s => s.ServerUrl?.ToString() ?? "").ToList();
    }

    private static string GetServerPanelTitle(int index, ServerConfig server)
    {
        string trimmed = (server.DisplayName ?? string.Empty).Trim();
        return string.IsNullOrEmpty(trimmed) ? $"Server {index + 1}" : trimmed;
    }

    private static void RemoveAt<T>(List<T> list, int index)
    {
        if (index >= 0 && index < list.Count)
        {
            list.RemoveAt(index);
        }
    }

    private void AddServer()
    {
        _doc.Servers.Add(new ServerConfig
        {
            Authentication = new AuthenticationConfig(),
            WatcherPaths = [new WatcherPathEntry()]
        });
        _serverUrls.Add("");
    }

    private void RemoveServer(int index)
    {
        _doc.Servers.RemoveAt(index);
        _serverUrls.RemoveAt(index);
    }

    private async Task SaveAsync()
    {
        try
        {
            for (int i = 0; i < _doc.Servers.Count; i++)
            {
                string url = _serverUrls[i].Trim();
                _doc.Servers[i].ServerUrl = string.IsNullOrEmpty(url) ? null : new Uri(url, UriKind.Absolute);
            }

            foreach (ServerConfig s in _doc.Servers)
            {
                List<string> removedWatcherPaths = [];
                foreach (WatcherPathEntry e in s.WatcherPaths)
                {
                    string original = e.Path ?? string.Empty;
                    e.Path = PathNormalization.NormalizeDirectoryPath(e.Path);
                    if (!string.IsNullOrWhiteSpace(original) && string.IsNullOrWhiteSpace(e.Path))
                    {
                        removedWatcherPaths.Add(original);
                    }
                }

                s.WatcherPaths = s.WatcherPaths.Where(e => !string.IsNullOrWhiteSpace(e.Path)).ToList();
                if (removedWatcherPaths.Count > 0)
                {
                    string preview = string.Join(", ", removedWatcherPaths.Take(3));
                    string suffix = removedWatcherPaths.Count > 3 ? ", ..." : string.Empty;
                    Snackbar.Add(
                        $"Removed {removedWatcherPaths.Count} invalid watcher path(s): {preview}{suffix}",
                        Severity.Warning);
                }
            }

            List<DeleteOverlapWarningGroup> overlaps = FindDeleteOverlaps(_doc);
            if (overlaps.Count > 0)
            {
                DialogOptions options = new()
                {
                    MaxWidth = MaxWidth.Medium,
                    FullWidth = true,
                    CloseOnEscapeKey = true
                };

                DialogParameters<DeleteOverlapWarningDialog> parameters = new()
                {
                    { x => x.Groups, overlaps }
                };

                IDialogReference dialog = await DialogService.ShowAsync<DeleteOverlapWarningDialog>(
                    "Confirm deletion risk",
                    parameters,
                    options);

                DialogResult? result = await dialog.Result;
                if (result is null || result.Canceled)
                {
                    Snackbar.Add("Save canceled.", Severity.Info);
                    return;
                }
            }

            Store.Replace(_doc);
            _doc = Store.GetSnapshot();
            _serverUrls = _doc.Servers.Select(s => s.ServerUrl?.ToString() ?? "").ToList();
            await Runtime.RebuildWatchersAsync();
            Snackbar.Add("Configuration saved and watchers rebuilt.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private static List<DeleteOverlapWarningGroup> FindDeleteOverlaps(AgentSettingsDocument doc)
    {
        Dictionary<ServerConfig, string> serverDisplay = new();
        foreach (ServerConfig s in doc.Servers)
        {
            string trimmed = (s.DisplayName ?? string.Empty).Trim();
            serverDisplay[s] = !string.IsNullOrEmpty(trimmed)
                ? trimmed
                : (s.ServerUrl?.ToString() ?? "<no url>");
        }

        Dictionary<(string Path, bool Recursive, string FiltersKey), Dictionary<ServerConfig, bool>> byKey = new();

        foreach (ServerConfig server in doc.Servers)
        {
            foreach (WatcherPathEntry watch in server.WatcherPaths)
            {
                string normalizedPath = PathNormalization.NormalizeDirectoryPath(watch.Path);
                if (string.IsNullOrWhiteSpace(normalizedPath))
                {
                    continue;
                }

                IReadOnlyList<string> effectiveFilters = WatcherUploadFilterHelpers.GetEffectiveUploadFilters(watch);
                string filtersKey = WatcherUploadFilterHelpers.NormalizeFiltersKey(effectiveFilters);
                (string Path, bool Recursive, string FiltersKey) key =
                    (normalizedPath, watch.IncludeSubdirectories, filtersKey);

                if (!byKey.TryGetValue(key, out Dictionary<ServerConfig, bool>? servers))
                {
                    servers = new Dictionary<ServerConfig, bool>();
                    byKey[key] = servers;
                }

                bool deleteEnabledForServer = watch.DeleteAfterUpload;
                if (servers.TryGetValue(server, out bool existing))
                {
                    servers[server] = existing || deleteEnabledForServer;
                }
                else
                {
                    servers[server] = deleteEnabledForServer;
                }
            }
        }

        List<DeleteOverlapWarningGroup> groups = [];
        foreach (KeyValuePair<(string Path, bool Recursive, string FiltersKey), Dictionary<ServerConfig, bool>> item in byKey)
        {
            if (item.Value.Count < 2)
            {
                continue;
            }

            if (!item.Value.Values.Any(v => v))
            {
                continue;
            }

            groups.Add(new DeleteOverlapWarningGroup
            {
                Path = item.Key.Path,
                Recursive = item.Key.Recursive,
                FiltersKey = item.Key.FiltersKey,
                Servers = item.Value
                    .Select(kv => new DeleteOverlapWarningServerEntry
                    {
                        Display = serverDisplay.TryGetValue(kv.Key, out string? display) ? display : "<unknown>",
                        DeleteEnabled = kv.Value
                    })
                    .OrderByDescending(s => s.DeleteEnabled)
                    .ThenBy(s => s.Display, StringComparer.OrdinalIgnoreCase)
                    .ToList()
            });
        }

        return groups
            .OrderBy(g => g.Path, StringComparer.OrdinalIgnoreCase)
            .ThenBy(g => g.Recursive ? 0 : 1)
            .ThenBy(g => g.FiltersKey, StringComparer.Ordinal)
            .ToList();
    }

    private async Task BrowseWatcherPathAsync(ServerConfig server, int watcherIndex)
    {
        if (watcherIndex < 0 || watcherIndex >= server.WatcherPaths.Count)
        {
            return;
        }

        DialogOptions options = new()
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        DialogParameters<DirectoryBrowserDialog> parameters = new()
        {
            { x => x.InitialPath, server.WatcherPaths[watcherIndex].Path }
        };

        IDialogReference dialog = await DialogService.ShowAsync<DirectoryBrowserDialog>(
            "Browse directories",
            parameters,
            options);
        DialogResult? result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not string selected)
        {
            return;
        }

        server.WatcherPaths[watcherIndex].Path = selected;
    }
}
