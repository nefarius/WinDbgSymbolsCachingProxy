@page "/"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject HarvesterRuntime Runtime
@inject AgentSettingsStore Store
@inject HarvesterHealthState Health
@inject ISnackbar Snackbar

<PageTitle>Dashboard</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Dashboard</MudText>

<MudText Typo="Typo.body2" Class="mb-3">
    Server assembly version: <strong>@(_serverVersion ?? "—")</strong>
</MudText>

<MudGrid>
    <MudItem xs="12" md="6">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Harvesting</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudText Class="mb-2">
                    Status: <strong>@(Health.HarvestingEnabled ? "Running" : "Stopped")</strong>
                </MudText>
                <MudText Class="mb-4">Active watchers: @Health.ActiveWatcherCount</MudText>
                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Filled" Color="Color.Success"
                               Disabled="@(_isTogglingHarvesting || Health.HarvestingEnabled)"
                               OnClick="StartAsync">Start</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Error"
                               Disabled="@(_isTogglingHarvesting || !Health.HarvestingEnabled)"
                               OnClick="StopAsync">Stop</MudButton>
                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" md="6">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Uploads</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudText>Succeeded: @Health.UploadSuccessCount</MudText>
                <MudText>Failed: @Health.UploadFailureCount</MudText>
                <MudText Class="mt-2">Last upload (UTC): @(Health.LastUploadUtc?.ToString("u") ?? "—")</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Last error</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudText Typo="Typo.body2">@(Health.LastErrorUtc?.ToString("u") ?? "—")</MudText>
                <MudText Typo="Typo.body1" Class="mt-2">@(Health.LastErrorMessage ?? "None")</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Watchers</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudTable Items="@Health.Watchers" Hover="true" Dense="true" Breakpoint="Breakpoint.Sm">
                    <HeaderContent>
                        <MudTh>Path</MudTh>
                        <MudTh>Recursive</MudTh>
                        <MudTh>Events</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Path">@context.Path</MudTd>
                        <MudTd DataLabel="Recursive">@context.Recursive</MudTd>
                        <MudTd DataLabel="Events">@context.EventsEnabled</MudTd>
                    </RowTemplate>
                </MudTable>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Recent file activity</MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                               Disabled="@(Health.FileActivityHistory.Count == 0)"
                               OnClick="ClearFileActivityHistoryAsync">
                        Clear history
                    </MudButton>
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent>
                @if (Health.FileActivityHistory.Count == 0)
                {
                    <MudText Typo="Typo.body2">No watcher activity yet.</MudText>
                }
                else
                {
                    <MudTable Items="@Health.FileActivityHistory" Hover="true" Dense="true" Breakpoint="Breakpoint.Sm"
                              Style="width:100%; table-layout:fixed;">
                        <ColGroup>
                            <col style="width: 11.75rem;" />
                            <col />
                            <col style="width: 9rem;" />
                            <col style="width: 11rem;" />
                            <col style="width: 50%; max-width: 50%;" />
                        </ColGroup>
                        <HeaderContent>
                            <MudTh Style="width: 11.75rem;">Time (UTC)</MudTh>
                            <MudTh>File</MudTh>
                            <MudTh Style="width: 9rem;">Event</MudTh>
                            <MudTh Style="width: 11rem;">Server</MudTh>
                            <MudTh Style="max-width: 50%;">Details</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Time (UTC)" Style="width: 11.75rem; white-space: nowrap;">@context.TimestampUtc.ToString("u")</MudTd>
                            <MudTd DataLabel="File" Style="min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@context.FileName</MudTd>
                            <MudTd DataLabel="Event" Style="width: 9rem; white-space: nowrap;">@GetStatusLabel(context.Status)</MudTd>
                            <MudTd DataLabel="Server" Style="width: 11rem; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                @if (!string.IsNullOrEmpty(context.ServerDisplayName) && !string.IsNullOrEmpty(context.ServerUrl))
                                {
                                    <MudTooltip Text="@context.ServerUrl">
                                        <span style="display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@context.ServerDisplayName</span>
                                    </MudTooltip>
                                }
                                else
                                {
                                    @(context.ServerDisplayName ?? context.ServerUrl ?? "—")
                                }
                            </MudTd>
                            <MudTd DataLabel="Details" Style="min-width: 0; max-width: 50%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                @if (!string.IsNullOrWhiteSpace(context.Details))
                                {
                                    <MudTooltip Text="@context.Details">
                                        <span style="display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@context.Details</span>
                                    </MudTooltip>
                                }
                                else
                                {
                                    <text>—</text>
                                }
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private bool _disposed;
    private bool _isTogglingHarvesting;
    private string? _serverVersion;

    protected override void OnInitialized()
    {
        _serverVersion = ApplicationVersionHelper.TryGetServerVersion();
        Health.Changed += OnHealthChanged;
    }

    private void OnHealthChanged()
    {
        if (_disposed)
        {
            return;
        }

        _ = InvokeAsync(() =>
        {
            if (_disposed)
            {
                return;
            }

            StateHasChanged();
        });
    }

    private async Task StartAsync()
    {
        if (_isTogglingHarvesting)
        {
            return;
        }

        try
        {
            _isTogglingHarvesting = true;
            await Runtime.SetHarvestingEnabledAsync(true);
            Snackbar.Add("Harvesting started.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _isTogglingHarvesting = false;
        }
    }

    private async Task StopAsync()
    {
        if (_isTogglingHarvesting)
        {
            return;
        }

        try
        {
            _isTogglingHarvesting = true;
            await Runtime.SetHarvestingEnabledAsync(false);
            Snackbar.Add("Harvesting stopped.", Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _isTogglingHarvesting = false;
        }
    }

    private Task ClearFileActivityHistoryAsync()
    {
        Health.ClearFileActivityHistory();
        Snackbar.Add("File activity history cleared.", Severity.Success);
        return Task.CompletedTask;
    }

    public ValueTask DisposeAsync()
    {
        Health.Changed -= OnHealthChanged;
        _disposed = true;
        return ValueTask.CompletedTask;
    }

    private static string GetStatusLabel(FileActivityStatus status) => status switch
    {
        FileActivityStatus.Detected => "Detected",
        FileActivityStatus.UploadSucceeded => "Uploaded",
        FileActivityStatus.UploadFailed => "Upload failed",
        FileActivityStatus.Deleted => "Deleted",
        FileActivityStatus.DeleteSkipped => "Delete skipped",
        FileActivityStatus.DeleteFailed => "Failed to delete",
        _ => status.ToString()
    };
}
